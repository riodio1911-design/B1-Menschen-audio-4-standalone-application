{
  "3b8101abf5fbbc7c67c96fc22cc1254c99368ea9b5d07c00573878168a6b4f9b": "der/die Auszubildende",
  "e55f535f9bc032b5707ace43f8e577f0deaa37fc404d306d521e7fd0116c9318": "der Erzieher",
  "c2d278502bdf4daf733b886e479a981b5974ddcebf1ce2095189b96cbd433544": "die Leistung",
  "69db7583405bb5922c08802d5d73d0e0bb2d55741127dc537d67006c2ea38796": "In der Praxis sieht das anders aus.",
  "777125b42fde4f7d3cdd0aa4e68ddb9a48bbb363b2f50ef2772c899459d0f85d": "die Verantwortung",
  "f2c3f56ea5544079cbaf8d7260db27a1f7b539fd9389ac095e4a1d23bce6bceb": "Er beschäftigt sich mit dem Thema.",
  "5bb007b86199f3953ee9b0d8d490e3cff03afb5ef7a963fe8163c3b0ae63b028": "duzen",
  "bfdda9198f2225715c1b9462b38b7d4803f7db7128f399fba375e71cacd29c1d": "Hier duzen sich alle Kollegen.",
  "bd05399286fe4fce01585a0f94e13a644cd2d014e735402f35499760a604d26d": "erledigen",
  "6d49b787ae28a0b8a4decbff20e162dfbf3814b4393215e45444b501d81b9407": "Ich muss noch etwas erledigen.",
  "55d531f14465fce1d0e4c50aee34f0206b7e425284188844d333d2f46bd673f0": "übernehmen",
  "1d68e29a3bbeda9e72bb6cafeed6b357b6a10ab0e6990185235ac8edaf41c89e": "Wirst du das Projekt übernehmen?",
  "fea069c544d4740afca081a3a85363692570a0e03e6d7afd4d14c9c7617cd6b4": "zuverlässig",
  "96e7183c8bc4c2b4a3c10722a2f14a5b4d81d2beac23414cb837c23fadf9167d": "Was bleibt netto übrig?",
  "03a1f1cbbdcc75280af85be4499e75689f1b7c2ba91bfd7bae5cbdec28ff3121": "die Gelegenheit",
  "2304ef4d28abe1342a519d2206b83be506e48e0926ab458f22a9a667469890a5": "der Lärm",
  "3d9503d80184320a912905f5f4446b3a17b19a739a865767100a51073a7c8e5d": "Der Lärm ist unerträglich.",
  "704c0451933ca9c191e8e30812b93bb1abf9fd7f4dd8f00eb378899345a6b53a": "entschließen (sich)",
  "fcededbcc38c969fed27c753f91bdcee5f2b32027a0690d92022ae3017095a67": "Wir haben uns entschlossen zu bleiben.",
  "dc0647cf503305763b5540501c88791b602b44baca34cb434bb487c1d212b9af": "erwarten",
  "7693312cdc92175b0e0caa9af8ef6e6ad16e419ed04167a14ec327cee9598226": "Ich erwarte viel von dir.",
  "4ff1e8d3697d633dd4fb58300e17e812c4320cb1c46d051a3aa90ee4a15e5ed0": "Sie führt uns durch das Museum.",
  "a6f3d347909e60baaa5d890a88ba03f398ccdfdfddaf6f519295d5ece1a7ce2e": "überlegen",
  "69d94ec018a765ab179f43f9dbe766193a1837aa0ea2e5d70c158bbb133b785d": "Lass mich kurz überlegen.",
  "aa498e66a19f6dfe3138952ddc00f8fa9b6c4f4e9c875c49878e3f3081df328e": "übrig bleiben",
  "52b6e459b3256857ad392b2640c62250a3969ea77aada53581aa06ab6292aabd": "vorstellen (sich)",
  "ff4ff78d642610e97d84e6061671a70000f075ec7244b23d3b511642d8ddab32": "Ich kann mir das gut vorstellen.",
  "7db06f35229d69e542681ca09ca9903938caa6f00854beedd255bfc736b3325c": "zurechtkommen",
  "878ee717d0fbc617e8f2e26f230ae8ed5047a185b4ed067919440f03f5f70f3f": "Sie ist sehr engagiert und sozial.",
  "e26b760fb3049d0c320cc7c4f7f296014085201311b1f3931cc4beecde28247b": "die Unterkunft",
  "34107eca56547c3952185ec579f5cd896ac6b6e2d315ba6e2c8602edbec80eab": "Hallo! Lass uns über deinen ersten Arbeitstag (oder dein erstes Praktikum) sprechen.\n\nIch frage dich und du antwortest und bewertest (đánh giá) das Erlebnis. Nutze dafür Redemittel wie:\n- Der erste Tag ist mir in guter Erinnerung geblieben.\n- Besonders gut / nicht so gut gefiel mir...\n- Das fand ich sehr angenehm / enttäuschend.\n\nLass uns anfangen: Erzähl mal, wie war dein erster Arbeitstag?",
  "f823f1a1e4061ba9f42e6fec791bdf4cac9329331931cf1607139bacc7a7f0ca": "Wie war dein erstes Praktikum?"
}